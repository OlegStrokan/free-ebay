{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=auth_service;Username=postgres;Password=postgres"
  },
  "GrpcServices": {
    "UserUrl": "http://user-service:8080"
  },
  "Jwt": {
    "SecretKey": "super_secret_auth_key_that_is_at_least_32_chars",
    "Issuer": "AuthService",
    "Audience": "ApiGateway",
    "AccessTokenExpirationMinutes": "60"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "EmailEventsTopic": "email.events"
  },
  "Email": {
    "FromAddress": "no-reply@free-ebay.com"
  },
  "App": {
    "FrontendUrl": "http://localhost:3000"
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "AllowedHosts": "*"
}
