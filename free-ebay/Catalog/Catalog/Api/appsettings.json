{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ConsumerGroupId": "catalog-service",
    "ProductEventsTopic": "product.events"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "IndexName": "products"
  },
  "RetryStore": {
    "ConnectionString": "Host=localhost;Port=5432;Database=catalog_retry;Username=postgres;Password=postgres",
    "WorkerRetryLimit": 15,
    "WorkerPollIntervalSeconds": 180,
    "WorkerBatchSize": 50
  },
  "Otel": {
    "Endpoint": "http://localhost:4317"
  }
}
