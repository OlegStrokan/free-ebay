{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5436;Database=payment_db;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9093",
    "SagaTopic": "order.events"
  },
  "Stripe": {
    "UseFakeProvider": true,
    "WebhookSecret": "dev_webhook_secret"
  },
  "OrderCallback": {
    "EndpointUrl": "http://localhost:5224/api/v1/payment/webhooks/stripe-result",
    "SharedSecret": "dev_shared_secret"
  },
  "ReconciliationWorker": {
    "Enabled": true,
    "IntervalSeconds": 30,
    "OlderThanMinutes": 5,
    "BatchSize": 100
  },
  "Admin": {
    "ApiKey": "dev-admin-key"
  }
}